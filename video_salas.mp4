                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- TOP ANUNCIOS TAB -->
        <div id="top-anuncios" class="tab-content">
            <div class="section">
                <h3 class="section-title">Top Anuncios por Clics (FB + IG)</h3>
                <div class="chart-container"><canvas id="chart-top-clics"></canvas></div>
            </div>

            <div class="section">
                <h3 class="section-title">Videos de Creativos</h3>
                <div class="video-gallery">
                    <!-- 1. Cocina - 115 clics -->
                    <div class="video-card">
