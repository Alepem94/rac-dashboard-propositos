        </div>

        <!-- HALLAZGOS TAB -->
        <div id="hallazgos" class="tab-content">
            <div class="section">
                <h3 class="section-title">Hallazgos Clave</h3>
                <div id="hallazgos-list">
                    <div class="hallazgo">
                        <strong>📈 Interacciones sobresalientes:</strong> Las campañas de interacción superaron significativamente las metas (hasta 4,198% en IG NL).
                    </div>
                    <div class="hallazgo">
                        <strong>⚠️ Alcance Morelia por debajo de meta:</strong> FB e IG no alcanzaron las metas de alcance en Morelia (83-84%).
                    </div>
                    <div class="hallazgo">
                        <strong>🎯 YouTube alto rendimiento:</strong> Ambas audiencias superaron metas de TrueViews con CPV eficiente ($0.025 promedio).
                    </div>
                    <div class="hallazgo">
                        <strong>📱 TikTok Morelia bajo:</strong> Solo alcanzó 37% de la meta de views +6s. NL cumplió con 106%.
                    </div>
                    <div class="hallazgo">
                        <strong>🔥 Producto estrella:</strong> Cocina lidera en clics (115) e inversión. Motos segundo lugar.
                    </div>
                </div>
                <div class="hallazgo-controls">
                    <button class="btn btn-primary" onclick="addHallazgo()">+ Agregar Hallazgo</button>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Tab Navigation
        function showTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            event.target.classList.add('active');
        }

        // Carousel Functions
        const carouselPositions = {};
        function moveCarousel(carouselId, direction) {
            const carousel = document.getElementById(carouselId);
            const slides = carousel.querySelectorAll('.carousel-slide');
            const totalSlides = slides.length;
            
            if (!carouselPositions[carouselId]) carouselPositions[carouselId] = 0;
            carouselPositions[carouselId] += direction;
            
            if (carouselPositions[carouselId] < 0) carouselPositions[carouselId] = totalSlides - 1;
            if (carouselPositions[carouselId] >= totalSlides) carouselPositions[carouselId] = 0;
            
            updateCarousel(carouselId);
        }
        
        function goToSlide(carouselId, index) {
            carouselPositions[carouselId] = index;
            updateCarousel(carouselId);
        }
        
        function updateCarousel(carouselId) {
            const carousel = document.getElementById(carouselId);
            const slides = carousel.querySelectorAll('.carousel-slide');
            const position = carouselPositions[carouselId] || 0;
            
            slides.forEach((slide, i) => {
                slide.style.transform = `translateX(-${position * 100}%)`;
            });
            
            const nav = document.getElementById('nav-' + carouselId);
            if (nav) {
                nav.querySelectorAll('.carousel-dot').forEach((dot, i) => {
                    dot.classList.toggle('active', i === position);
                });
            }
        }

        // Chart.js Config
        Chart.defaults.font.family = "'Segoe UI', sans-serif";
        Chart.defaults.plugins.legend.position = 'bottom';
        
        const colors = {
            azul: '#1E3A6E',
            rojo: '#E31E24',
            amarillo: '#F7D117',
            verde: '#28a745',
            azulClaro: '#4a90d9',
            gris: '#6c757d'
        };

        // OVERVIEW CHARTS
        // Inversión por Audiencia (Doughnut)
        new Chart(document.getElementById('chart-inv-audiencia'), {
            type: 'doughnut',
            data: {
                labels: ['Morelia', 'NL y Jalisco'],
                datasets: [{
                    data: [100638, 49996],
                    backgroundColor: [colors.azul, colors.rojo],
                    borderWidth: 0
                }]
            },
            options: {
                plugins: {
                    legend: { position: 'bottom' },
                    tooltip: {
                        callbacks: {
                            label: ctx => `${ctx.label}: $${ctx.raw.toLocaleString()} MXN`
                        }
                    }
                }
            }
        });

        // Inversión por Plataforma
        new Chart(document.getElementById('chart-inv-plataforma'), {
            type: 'bar',
            data: {
                labels: ['TikTok', 'Facebook', 'Instagram', 'YouTube', 'GA Display'],
                datasets: [{
                    data: [51918, 46790, 23280, 15001, 13646],
                    backgroundColor: [colors.azul, '#1877F2', '#E4405F', '#FF0000', colors.amarillo]
                }]
            },
            options: {
                indexAxis: 'y',
                plugins: { legend: { display: false } },
                scales: {
                    x: { ticks: { callback: v => '$' + (v/1000).toFixed(0) + 'K' } }
                }
            }
        });

        // Carrusel - Alcance por Audiencia
        new Chart(document.getElementById('chart-alcance-aud'), {
            type: 'bar',
            data: {
                labels: ['Morelia', 'NL y Jalisco'],
                datasets: [
                    { label: 'Facebook', data: [929567, 690364], backgroundColor: '#1877F2' },
                    { label: 'Instagram', data: [329102, 468676], backgroundColor: '#E4405F' }
                ]
            },
            options: {
                scales: { y: { ticks: { callback: v => (v/1000000).toFixed(1) + 'M' } } }
            }
        });

        // Carrusel - Interacciones por Audiencia
        new Chart(document.getElementById('chart-int-aud'), {
            type: 'bar',
            data: {
                labels: ['Morelia', 'NL y Jalisco'],
                datasets: [
                    { label: 'Facebook', data: [707089, 550806], backgroundColor: '#1877F2' },
                    { label: 'Instagram', data: [157308, 320154], backgroundColor: '#E4405F' }
                ]
            },
            options: {
                scales: { y: { ticks: { callback: v => (v/1000).toFixed(0) + 'K' } } }
            }
        });

        // Carrusel - TikTok Views por Audiencia
        new Chart(document.getElementById('chart-tiktok-aud'), {
            type: 'bar',
            data: {
                labels: ['NL y Jalisco', 'Morelia'],
                datasets: [
                    { label: 'Resultado', data: [239037, 183245], backgroundColor: colors.azul },
                    { label: 'Meta', data: [225000, 500000], backgroundColor: colors.gris }
                ]
            },
            options: {
                scales: { y: { ticks: { callback: v => (v/1000).toFixed(0) + 'K' } } }
            }
        });

        // Carrusel - YouTube TrueViews por Audiencia
        new Chart(document.getElementById('chart-yt-aud'), {
            type: 'bar',
            data: {
                labels: ['Morelia', 'NL y Jalisco'],
                datasets: [
                    { label: 'TrueViews', data: [420592, 183929], backgroundColor: colors.rojo },
                    { label: 'Meta', data: [250000, 125000], backgroundColor: colors.gris }
                ]
            },
            options: {
                scales: { y: { ticks: { callback: v => (v/1000).toFixed(0) + 'K' } } }
            }
        });

        // Producto - Inversión
        new Chart(document.getElementById('chart-prod-inv'), {
            type: 'bar',
            data: {
                labels: ['Cocina', 'Motos', 'Celular', 'TV', 'Laptop', 'Sala'],
                datasets: [{
                    data: [24249, 18828, 10483, 9367, 4746, 2396],
                    backgroundColor: colors.azul
                }]
            },
            options: {
                indexAxis: 'y',
                plugins: { legend: { display: false } },
                scales: { x: { ticks: { callback: v => '$' + (v/1000).toFixed(0) + 'K' } } }
            }
        });

        // Producto - Clics
        new Chart(document.getElementById('chart-prod-clics'), {
            type: 'bar',
            data: {
                labels: ['Cocina', 'Motos', 'Laptop', 'TV', 'Celular', 'Sala'],
                datasets: [{
                    data: [115, 82, 72, 63, 44, 21],
                    backgroundColor: colors.rojo
                }]
            },
            options: {
                indexAxis: 'y',
                plugins: { legend: { display: false } }
            }
        });

        // FACEBOOK CHARTS
        new Chart(document.getElementById('chart-fb-alcance'), {
            type: 'bar',
            data: {
                labels: ['Morelia', 'NL y Jalisco'],
                datasets: [
                    { label: 'Resultado', data: [929567, 690364], backgroundColor: '#1877F2' },
                    { label: 'Meta', data: [1124859, 506187], backgroundColor: colors.gris }
                ]
            },
            options: { scales: { y: { ticks: { callback: v => (v/1000000).toFixed(1) + 'M' } } } }
        });

        new Chart(document.getElementById('chart-fb-int'), {
            type: 'bar',
            data: {
                labels: ['Morelia', 'NL y Jalisco'],
                datasets: [
                    { label: 'Resultado', data: [707089, 550806], backgroundColor: '#1877F2' },
                    { label: 'Meta', data: [38596, 17544], backgroundColor: colors.gris }
                ]
            },
            options: { scales: { y: { ticks: { callback: v => (v/1000).toFixed(0) + 'K' } } } }
        });

        // INSTAGRAM CHARTS
        new Chart(document.getElementById('chart-ig-alcance'), {
            type: 'bar',
            data: {
                labels: ['NL y Jalisco', 'Morelia'],
                datasets: [
                    { label: 'Resultado', data: [468676, 329102], backgroundColor: '#E4405F' },
                    { label: 'Meta', data: [449944, 393701], backgroundColor: colors.gris }
                ]
            },
            options: { scales: { y: { ticks: { callback: v => (v/1000).toFixed(0) + 'K' } } } }
        });

        new Chart(document.getElementById('chart-ig-int'), {
            type: 'bar',
            data: {
                labels: ['NL y Jalisco', 'Morelia'],
                datasets: [
                    { label: 'Resultado', data: [320154, 157308], backgroundColor: '#E4405F' },
                    { label: 'Meta', data: [7627, 6780], backgroundColor: colors.gris }
                ]
            },
            options: { scales: { y: { ticks: { callback: v => (v/1000).toFixed(0) + 'K' } } } }
        });

        // TIKTOK CHARTS
        new Chart(document.getElementById('chart-tt-views'), {
            type: 'bar',
            data: {
                labels: ['NL y Jalisco', 'Morelia'],
                datasets: [
                    { label: 'Resultado', data: [239037, 183245], backgroundColor: '#000000' },
                    { label: 'Meta', data: [225000, 500000], backgroundColor: colors.gris }
                ]
            },
            options: { scales: { y: { ticks: { callback: v => (v/1000).toFixed(0) + 'K' } } } }
        });

        new Chart(document.getElementById('chart-tt-videoviews'), {
            type: 'bar',
            data: {
                labels: ['Morelia', 'NL y Jalisco'],
                datasets: [{
                    label: 'Video Views',
                    data: [3091745, 2480599],
                    backgroundColor: ['#000000', '#333333']
                }]
            },
            options: { scales: { y: { ticks: { callback: v => (v/1000000).toFixed(1) + 'M' } } } }
        });

        new Chart(document.getElementById('chart-tt-producto'), {
            type: 'bar',
            data: {
                labels: ['Motos', 'Cocina', 'Sala', 'Celular', 'Laptop'],
                datasets: [{
                    label: 'Views +6s',
                    data: [196573, 88302, 67990, 20347, 7568],
                    backgroundColor: '#000000'
                }]
            },
            options: {
                indexAxis: 'y',
                scales: { x: { ticks: { callback: v => (v/1000).toFixed(0) + 'K' } } }
            }
        });

        // YOUTUBE CHARTS
        new Chart(document.getElementById('chart-yt-comp'), {
            type: 'bar',
            data: {
                labels: ['Morelia', 'NL y Jalisco'],
                datasets: [
                    { label: 'TrueViews', data: [420592, 183929], backgroundColor: colors.rojo },
                    { label: 'Meta', data: [250000, 125000], backgroundColor: colors.gris }
                ]
            },
            options: {
                scales: { y: { ticks: { callback: v => (v/1000).toFixed(0) + 'K' } } }
            }
        });

        // TOP ANUNCIOS
        new Chart(document.getElementById('chart-top-clics'), {
            type: 'bar',
            data: {
                labels: ['Cocina', 'Motos', 'Laptop', 'TV', 'Celular', 'Sala'],
                datasets: [{
                    label: 'Clics',
                    data: [115, 82, 72, 63, 44, 21],
                    backgroundColor: [colors.azul, colors.rojo, colors.amarillo, colors.verde, colors.azulClaro, colors.gris]
                }]
            },
            options: {
                plugins: { legend: { display: false } }
            }
        });

        // Hallazgos Functions
        function addHallazgo() {
            const container = document.getElementById('hallazgos-list');
            const div = document.createElement('div');
            div.className = 'hallazgo';
            div.innerHTML = `
                <textarea style="width:100%; min-height:60px; border:1px solid #ddd; border-radius:4px; padding:10px;" placeholder="Escribe tu hallazgo aquí..."></textarea>
                <button class="btn btn-danger" style="margin-top:10px;" onclick="this.parentElement.remove()">Eliminar</button>
            `;
            container.appendChild(div);
        }
    </script>
</body>
</html>
